{
  "name": "flux-project",
  "displayName": "Flux Project Support",
  "description": "Project management for Flux",
  "version": "0.1.0",
  "publisher": "flux",
  "main": "./src/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:flux.createProject",
    "onCommand:flux.fpmInstall",
    "onCommand:flux.fpmUpdate",
    "onCommand:flux.fpmList",
    "onCommand:flux.fpmAddSource",
    "workspaceContains:flux.toml"
  ],
  "contributes": {
    "commands": [
      {
        "command": "flux.createProject",
        "title": "Flux: Create New Project",
        "category": "Flux"
      },
      {
        "command": "flux.fpmInstall",
        "title": "FPM: Install Package",
        "category": "Flux"
      },
      {
        "command": "flux.fpmUpdate",
        "title": "FPM: Update All",
        "category": "Flux"
      },
      {
        "command": "flux.fpmList",
        "title": "FPM: List Installed",
        "category": "Flux"
      },
      {
        "command": "flux.fpmAddSource",
        "title": "FPM: Add Source",
        "category": "Flux"
      }
    ],
    "configuration": {
      "title": "Flux",
      "properties": {
        "flux.compilerPath": {
          "type": "string",
          "default": "fluxc",
          "description": "Path to the fluxc compiler"
        },
        "flux.fpmPath": {
          "type": "string",
          "default": "fpm.py",
          "description": "Path to the fpm.py script"
        }
      }
    }
  }
}
