{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Flux: Build",
            "type": "shell",
            "command": "fluxc build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$fluxc"
        },
        {
            "label": "Flux: Run",
            "type": "shell",
            "command": "fluxc run",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": "$fluxc"
        }
    ]
}
