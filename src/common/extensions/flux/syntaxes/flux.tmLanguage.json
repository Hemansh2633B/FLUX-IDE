{
  "scopeName": "source.fx",
  "name": "Flux",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.fx",
          "match": "//.*$"
        },
        {
          "name": "comment.block.fx",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fx",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.fx",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.fx",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.fx",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fx",
          "match": "\\b(if|else|elif|for|in|while|do|break|continue|return|escape|switch|case|default|try|catch|throw|goto|label|noreturn)\\b"
        },
        {
          "name": "keyword.other.fx",
          "match": "\\b(def|cdecl|stdcall|fastcall|thiscall|vectorcall|struct|object|trait|namespace|using|as|is|and|or|not|xor|import|export|extern|global|local|register|volatile|const|heap|stack|noinit|singinit|alignof|sizeof|assert|deprecate|asm|auto|template|contract)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.fx",
          "match": "\\b(int|uint|long|ulong|float|double|bool|byte|char|void|data|signed|unsigned|this)\\b"
        },
        {
          "name": "entity.name.type.fx",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.fx",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.numeric.hex.fx",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.decimal.fx",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.fx"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.fx",
          "match": "(\\+|\\-|\\*|/|%|=|==|!=|<|>|<=|>=|&|\\||\\^|~|<<|>>|\\.|->|<~|\\?)"
        }
      ]
    }
  }
}
